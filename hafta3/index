<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Hafta 3 — İletişim Formu</title>
  <link rel="stylesheet" href="../hafta1/style.css" />
  <style>
    /* contact-container — ana CSS temasıyla uyumlu */
    .contact-container {
      width: 100%;
      max-width: 620px;
      margin: 0 auto;
      background: rgba(255,255,255,0.85);
      border: 1.5px solid #c7d8f8;
      border-radius: 16px;
      padding: 2.5rem 2.8rem;
      box-shadow: 0 4px 24px rgba(30,64,175,0.10);
      backdrop-filter: blur(8px);
    }

    .contact-container h2 {
      font-size: 1.4rem;
      font-weight: 800;
      color: #1e40af;
      text-align: center;
      margin-bottom: 1.8rem;
      display: block;
    }

    .contact-container h2::before { display: none; }

    label {
      display: block;
      font-weight: 700;
      font-size: 0.88rem;
      color: #1e40af;
      margin-bottom: 0.4rem;
      margin-top: 1.1rem;
    }

    input[type="text"],
    input[type="email"],
    input[type="password"],
    select,
    textarea {
      width: 100%;
      padding: 0.75rem 1rem;
      border: 1.5px solid #c7d8f8;
      border-radius: 10px;
      font-size: 0.92rem;
      font-family: inherit;
      color: #1e293b;
      background: #f0f4ff;
      outline: none;
      transition: border-color 0.2s, box-shadow 0.2s, background 0.2s;
      box-sizing: border-box;
    }

    input:focus, select:focus, textarea:focus {
      border-color: #2563eb;
      background: #ffffff;
      box-shadow: 0 0 0 3px rgba(37,99,235,0.12);
    }

    .option-group {
      background: #f0f4ff;
      border: 1.5px solid #c7d8f8;
      border-radius: 10px;
      padding: 0.9rem 1.1rem;
      display: flex;
      flex-direction: column;
      gap: 0.55rem;
    }

    .option-group label {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      font-weight: 400;
      font-size: 0.92rem;
      color: #334155;
      margin: 0;
      cursor: pointer;
    }

    .option-group input[type="radio"],
    .option-group input[type="checkbox"] {
      width: 16px;
      height: 16px;
      margin: 0;
      padding: 0;
      border: none;
      box-shadow: none;
      accent-color: #2563eb;
      flex-shrink: 0;
    }

    textarea { resize: vertical; min-height: 120px; }

    input[type="file"] {
      border: none;
      padding: 0;
      font-size: 0.88rem;
      color: #475569;
      background: transparent;
      width: auto;
      cursor: pointer;
    }

    .btn-group {
      display: flex;
      gap: 0.8rem;
      margin-top: 1.6rem;
    }

    .btn-gonder {
      flex: 1;
      padding: 0.85rem 1rem;
      background: #1e3a8a;
      color: #fff;
      border: none;
      border-radius: 10px;
      font-size: 1rem;
      font-weight: 700;
      cursor: pointer;
      transition: background 0.2s, transform 0.15s, box-shadow 0.2s;
    }
    .btn-gonder:hover {
      background: #2563eb;
      transform: translateY(-2px);
      box-shadow: 0 6px 20px rgba(37,99,235,0.25);
    }

    .btn-temizle {
      flex: 1;
      padding: 0.85rem 1rem;
      background: #f0f4ff;
      color: #1e40af;
      border: 1.5px solid #c7d8f8;
      border-radius: 10px;
      font-size: 1rem;
      font-weight: 700;
      cursor: pointer;
      transition: background 0.2s, transform 0.15s, border-color 0.2s;
    }
    .btn-temizle:hover {
      background: #e8eeff;
      border-color: #2563eb;
      transform: translateY(-2px);
    }
  </style>
</head>
<body>
  <div class="kapsayici">

    <header>
      <h1>Hafta 3 — İletişim Formu</h1>
      <p>CSS Box Model · Form Tasarımı</p>
    </header>

    <nav>
      <ul>
        <li><a href="../hafta1/index.html">Ana Sayfa</a></li>
        <li><a href="../hafta1/about.html">Hakkımda</a></li>
        <li><a href="../hafta1/interests.html">İlgi Alanlarım</a></li>
        <li><a href="../hafta1/contact.html">İletişim</a></li>
        <li><a href="../hafta1/labs.html">Lab Ödevlerim</a></li>
        <li><a href="index.html" class="aktif">İletişim Formu</a></li>
      </ul>
    </nav>

    <div class="contact-container">
      <h2>Detaylı İletişim Formu</h2>
      <p style="text-align:center;font-size:0.8rem;color:#64748b;margin-bottom:0.5rem;"><span style="color:#e11d48">*</span> zorunlu alanlar</p>

      <label for="ad-soyad">Ad Soyad: <span style="color:#e11d48">*</span></label>
      <input type="text" id="ad-soyad" placeholder="Örn: Yusuf Durmuş" />

      <label for="eposta">E-posta Adresi: <span style="color:#e11d48">*</span></label>
      <input type="email" id="eposta" placeholder="ornek@mail.com" />

      <label for="sifre">Başvuru Takip Şifresi:</label>
      <input type="password" id="sifre" placeholder="Şifrenizi girin" />

      <label>İletişim Tercihi:</label>
      <div class="option-group">
        <label><input type="radio" name="iletisim" checked /> Bana e-posta ile ulaşın</label>
        <label><input type="radio" name="iletisim" /> Bana telefonla ulaşın</label>
      </div>

      <label>İlgi Alanları / Yetenekler:</label>
      <div class="option-group">
        <label><input type="checkbox" /> HTML</label>
        <label><input type="checkbox" /> CSS</label>
        <label><input type="checkbox" /> Algoritma</label>
      </div>

      <label for="konu">Konu: <span style="color:#e11d48">*</span></label>
      <select id="konu">
        <option value="">Lütfen bir konu seçin...</option>
        <option>İş Teklifi</option>
        <option>Soru</option>
        <option>Geri Bildirim</option>
      </select>

      <label for="dosya">Özgeçmiş (CV) veya Fotoğraf Yükle:</label>
      <input type="file" id="dosya" />

      <label for="mesaj">Mesajınız: <span style="color:#e11d48">*</span></label>
      <textarea id="mesaj" placeholder="Detaylı mesajınızı buraya yazabilirsiniz..."></textarea>

      <div class="btn-group">
        <button class="btn-gonder" onclick="gonder()">Gönder</button>
        <button class="btn-temizle" onclick="temizle()">Temizle</button>
      </div>
    </div>

    <br>

    <footer>
      <p>© 2026 Yusuf Durmuş (170423965) | Web Programlama Dersi</p>
    </footer>

  </div>

  <script>
    function gonder() {
      const ad = document.getElementById('ad-soyad').value.trim();
      const ep = document.getElementById('eposta').value.trim();
      if (!ad || !ep) { alert('Lütfen Ad Soyad ve E-posta alanlarını doldurun.'); return; }
      alert('Teşekkürler ' + ad + '! Mesajınız alındı.');
    }
    function temizle() {
      document.querySelectorAll('input[type="text"], input[type="email"], input[type="password"], textarea, select')
        .forEach(el => el.value = '');
      document.querySelectorAll('input[type="checkbox"]').forEach(el => el.checked = false);
      document.querySelector('input[type="radio"]').checked = true;
    }
  </script>
</body>
</html>
